# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Get these from https://console.neon.tech → your project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_URL

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# Set to your Vercel deployment URL (e.g. https://aimpact.vercel.app)
AUTH_URL="https://your-app.vercel.app"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# Add your Vercel URL to Authorized redirect URIs:
#   https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Optional: Jira integration ───────────────────────────────────────────────
# JIRA_BASE_URL="https://yourorg.atlassian.net"
# JIRA_API_TOKEN="your-jira-api-token"
# JIRA_EMAIL="your-email@yourorg.com"
